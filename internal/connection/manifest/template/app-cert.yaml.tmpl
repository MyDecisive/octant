apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: cert-manager
  namespace: {{ .ArgoCDNamespace }}
spec:
  project: default
  source:
    repoURL: quay.io/jetstack/charts
    chart: cert-manager
    targetRevision: {{ .Version }}
    helm:
      parameters:
      - name: "crds.enabled"
        value: "true"
  destination:
    name: "in-cluster"
    namespace: {{ .Namespace }}
  syncPolicy:
    automated:
      enabled: true
      prune: true
    syncOptions:
    - PruneLast=true
    - CreateNamespace=true
    retry:
      limit: 1