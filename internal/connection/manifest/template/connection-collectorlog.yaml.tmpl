apiVersion: opentelemetry.io/v1beta1
kind: OpenTelemetryCollector
metadata:
  name: {{ .Name }}-log-sampling
  namespace: {{ .Namespace }}
  labels:
    app: {{ .Name }}
    app.kubernetes.io/instance: {{ .Name }}-log-sampling
    mydecisive.ai/hub-name: {{ .Name }}
  {{- if .IsArgoSideload }}
  annotations:
    argocd.argoproj.io/tracking-id: {{ .Name }}:opentelemetry.io/OpenTelemetryCollector:mdai/{{ .Name }}-log-sampling
    argocd.argoproj.io/sync-options: Force=true,Replace=true
    argocd.argoproj.io/sync-wave: "1"
  {{- end }}
spec:
  managementState: managed
  image: ghcr.io/open-telemetry/opentelemetry-collector-releases/opentelemetry-collector-contrib:0.148.0
  {{- $replicas:=0}}
  {{- range .TelemetryTypes }}
    {{- if eq . "logs" }}
      {{- $replicas = 2}}
      {{- break }}
    {{- end }}
  {{- end }}
  replicas: {{$replicas | printf "%d"}}
  resources:
    requests:
      memory: "128Mi"
      cpu: "100m"
  env:
    {{- if .DatadogIntegrationData }}
    - name: DD_API_KEY
      valueFrom:
        secretKeyRef:
          name: {{ .Name }}-integration-secret
          key: api-key
    - name: DD_SITE
      valueFrom:
        secretKeyRef:
          name: {{ .Name }}-integration-secret
          key: site-url
    {{- end }}
  envFrom:
  - configMapRef:
      name: {{ .Name }}-variables
  config:
    receivers:
      otlp:
        protocols:
          grpc:
            endpoint: 0.0.0.0:4317
          http:
            endpoint: 0.0.0.0:4318
    processors:
      transform/log_priority:
        error_mode: ignore
        log_statements:
          - context: log
            statements:
              - set(attributes["sampling.priority"], 100) where "${env:LOGS_PERSIST_ERRORS}" == "true" and (severity_number >= SEVERITY_NUMBER_ERROR or attributes["status"] == "Error" or attributes["level"] == "ERROR")
      probabilistic_sampler/logs:
        mode: hash_seed
        hash_seed: 22
        sampling_percentage: ${env:LOGS_RATIO_NUMBER}
        attribute_source: record
        from_attribute: service
        sampling_priority: sampling.priority
      batch:
        timeout: 5s
        send_batch_size: 8192
        send_batch_max_size: 10000
      groupbyattrs:
        keys:
          - service
      resource/observer_receiver_tag:
        attributes:
          - key: observer_direction
            value: "received"
            action: upsert
      resource/observer_exporter_tag:
        attributes:
          - key: observer_direction
            value: "exported"
            action: upsert
    exporters:
      {{- if .DatadogIntegrationData }}
      datadog:
        api:
          key: ${env:DD_API_KEY}
          site: "${env:DD_SITE}"
      {{- end }}
      otlp/observer:
        endpoint: {{ .Name }}-mdai-observer-service.{{ .Namespace }}.svc.cluster.local:4317
        tls:
          insecure: true
    extensions:
      health_check:
        endpoint: 0.0.0.0:13133
      zpages:
        endpoint: 0.0.0.0:55679
    service:
      extensions: [health_check, zpages]
      pipelines:
        logs/datadog_sampling:
          receivers: [otlp]
          # Order matters: memory_limiter first, then mark errors,
          # then sample, then batch for export.
          processors: [
            transform/log_priority,
            probabilistic_sampler/logs,
            resource/observer_exporter_tag,
            groupbyattrs,
            batch
          ]
          exporters: [ datadog, otlp/observer ]
        logs/watch_receivers:
          receivers: [ otlp ]
          processors: [
            resource/observer_receiver_tag,
            groupbyattrs,
            batch
          ]
          exporters: [ otlp/observer ]
      telemetry:
        resource:
          mdai_connection: "{{ .Name }}"
          service.name: "{{ .Name }}-log-sampling-collector"
        metrics:
          readers:
            - pull:
                exporter:
                  prometheus:
                    host: "0.0.0.0"
                    port: 8888
                    with_resource_constant_labels:
                      included:
                        - mdai_connection
                        - service.name