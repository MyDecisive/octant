{{- $replicas:=0}}
{{- range .TelemetryTypes }}
  {{- if eq . "traces" }}
    {{- $replicas = 2}}
    {{- break }}
  {{- end }}
{{- end }}
apiVersion: opentelemetry.io/v1beta1
kind: OpenTelemetryCollector
metadata:
  name: {{ .Name }}-trace-sampling
  namespace: "{{ .Namespace }}"
  labels:
    app: "{{ .Name }}"
    app.kubernetes.io/instance: {{ .Name }}-trace-sampling
    mydecisive.ai/hub-name: "{{ .Name }}"
  annotations:
    argocd.argoproj.io/tracking-id: "{{ .Name }}:opentelemetry.io/OpenTelemetryCollector:{{ .Namespace }}/{{ .Name }}-trace-sampling"
    argocd.argoproj.io/sync-options: Force=true,Replace=true
    argocd.argoproj.io/sync-wave: "1"
    {{- if eq $replicas 0 }}
    # ArgoCD's bundled OpenTelemetryCollector health check reports 0/0 ready replicas as
    # Degraded; a deliberately scaled-to-zero collector must not drag down app health.
    argocd.argoproj.io/ignore-healthcheck: "true"
    {{- end }}
spec:
  managementState: managed
  image: ghcr.io/open-telemetry/opentelemetry-collector-releases/opentelemetry-collector-contrib:0.148.0
  observability:
    metrics:
      enableMetrics: true
  replicas: {{$replicas | printf "%d"}}
  resources:
    requests:
      memory: "128Mi"
      cpu: "100m"
  env:
  {{- if .DatadogIntegrationData }}
    - name: DD_API_KEY
      valueFrom:
        secretKeyRef:
          name: {{ .Name }}-integration-secret
          key: api-key
    - name: DD_SITE
      valueFrom:
        secretKeyRef:
          name: {{ .Name }}-integration-secret
          key: site-url
    {{- end }}
  envFrom:
  - configMapRef:
      name: {{ .Name }}-variables
  config:
    receivers:
      otlp:
        protocols:
          grpc:
            endpoint: 0.0.0.0:4317
          http:
            endpoint: 0.0.0.0:4318
    processors:
      deltatocumulative: {}
      resource/observer_receiver_tag:
        attributes:
          - key: observer_direction
            value: "received"
            action: upsert
      resource/observer_exporter_tag:
        attributes:
          - key: observer_direction
            value: "exported"
            action: upsert
      tail_sampling:
        decision_wait: 10s
        num_traces: 100000
        expected_new_traces_per_sec: 1000
        decision_cache:
          sampled_cache_size: 100000
          non_sampled_cache_size: 100000
        policies:
          - name: keep-errors
            type: and
            and:
              and_sub_policy:
                - name: errors-enabled-gate
                  type: ottl_condition
                  ottl_condition:
                    error_mode: ignore
                    span:
                      - '"${env:TRACES_PERSIST_ERRORS}" == "true"'
                - name: is-error-status
                  type: status_code
                  status_code:
                    status_codes: [ERROR]
          - name: ratio_mode_policy
            type: probabilistic
            probabilistic:
              sampling_percentage: ${env:TRACES_RATIO_NUMBER}
      batch:
        timeout: 5s
        send_batch_size: 8192
        send_batch_max_size: 10000
    exporters:
      {{- if .DatadogIntegrationData }}
      datadog:
        api:
          key: "${env:DD_API_KEY}"
          site: "${env:DD_SITE}"
      {{- end }}
      prometheus:
        endpoint: "0.0.0.0:8899"
        metric_expiration: 180m
        resource_to_telemetry_conversion:
          enabled: true
      otlp/observer:
        endpoint: {{ .Name }}-mdai-observer-service.{{ .Namespace }}.svc.cluster.local:4317
        tls:
          insecure: true
    extensions:
      health_check:
        endpoint: 0.0.0.0:13133
      zpages:
        endpoint: 0.0.0.0:55679
    service:
      extensions: [health_check, zpages]
      pipelines:
        traces/datadog_sampling:
          receivers: [otlp]
          processors: [
                         tail_sampling,
                         resource/observer_exporter_tag,
                         batch
          ]
          exporters: [ datadog, count/spans_by_facet ]
        traces/watch_receivers:
          receivers: [ otlp ]
          processors: [
            resource/observer_receiver_tag,
            groupbyattrs,
            batch
          ]
          exporters: [ otlp/observer ]
        metrics:
          receivers: [count/spans_by_facet]
          processors: [deltatocumulative]
          exporters: [prometheus]
      telemetry:
        resource:
          mdai_connection: "{{ .Name }}"
          service.name: "{{ .Name }}-trace-sampling-collector"
        metrics:
          readers:
            - pull:
                exporter:
                  prometheus:
                    host: "0.0.0.0"
                    port: 8888
                    with_resource_constant_labels:
                      included:
                        - mdai_connection
                        - service.name