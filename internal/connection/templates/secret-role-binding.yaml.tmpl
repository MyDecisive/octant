apiVersion: rbac.authorization.k8s.io/v1
kind: RoleBinding
metadata:
  name: {{ .AppName }}-integration-secret-role-binding
  namespace: {{ .Namespace }}
  labels:
    app: {{ .AppName }}
    app.kubernetes.io/instance: {{ .AppName }}
subjects:
  - kind: ServiceAccount
    name: {{ .ServiceAccount }}
    namespace: {{ .CurrentNamespace }}
roleRef:
  kind: Role
  name: {{ .AppName }}-integration-secret-role
  apiGroup: ""