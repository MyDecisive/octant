apiVersion: opentelemetry.io/v1beta1
kind: OpenTelemetryCollector
metadata:
  name: {{ .AppName }}-trace-sampling
  namespace: {{ .Namespace }}
  labels:
    app: {{ .AppName }}
    app.kubernetes.io/instance: {{ .AppName }}-trace-sampling
    mydecisive.ai/hub-name: {{ .AppName }}
  {{- if .IsArgoSideload }}
  annotations:
    argocd.argoproj.io/tracking-id: {{ .AppName }}:opentelemetry.io/OpenTelemetryCollector:mdai/{{ .AppName }}-trace-sampling
  {{- end }}
spec:
  managementState: managed
  image: ghcr.io/open-telemetry/opentelemetry-collector-releases/opentelemetry-collector-contrib:0.148.0
  replicas: 3
  resources:
    limits:
      memory: "256Mi"
      cpu: "200m"
    requests:
      memory: "128Mi"
      cpu: "100m"
  env:
  {{- if .DatadogIntegrationData }}
    - name: DD_API_KEY
      valueFrom:
        secretKeyRef:
          name: {{ .AppName }}-integration-secret
          key: api-key
    - name: DD_SITE
      valueFrom:
        secretKeyRef:
          name: {{ .AppName }}-integration-secret
          key: site-url
    {{- end }}
  envFrom:
  - configMapRef:
      name: {{ .AppName }}-variables
  config:
    receivers:
      otlp:
        protocols:
          grpc:
            endpoint: 0.0.0.0:4317
          http:
            endpoint: 0.0.0.0:4318
    processors:
      deltatocumulative: {}
      memory_limiter:
        check_interval: 1s
        limit_percentage: 80
        spike_limit_percentage: 25
      tail_sampling:
        decision_wait: 10s
        num_traces: 100000
        expected_new_traces_per_sec: 1000
        decision_cache:
          sampled_cache_size: 100000
          non_sampled_cache_size: 100000
        policies:
          - name: keep-errors
            type: and
            and:
              and_sub_policy:
                - name: errors-enabled-gate
                  type: ottl_condition
                  ottl_condition:
                    error_mode: ignore
                    span:
                      - '"${env:TRACES_PERSIST_ERRORS}" == "true"'
                - name: is-error-status
                  type: status_code
                  status_code:
                    status_codes: [ERROR]
          - name: ratio_mode_policy
            type: probabilistic
            probabilistic:
              sampling_percentage: ${env:TRACES_RATIO_NUMBER}
      batch:
        timeout: 5s
        send_batch_size: 8192
        send_batch_max_size: 10000
    exporters:
      {{- if .DatadogIntegrationData }}
      datadog:
        api:
          key: ${env:DD_API_KEY}
          site: "${env:DD_SITE}"
      {{- end }}
      prometheus:
        endpoint: "0.0.0.0:8899"
        metric_expiration: 180m
        resource_to_telemetry_conversion:
          enabled: true
    connectors:
      count/spans_by_facet:
        spans:
          trace.span.service.total:
            description: Total span count by service (all spans).
          trace.span.service.root:
            description: Root span count by service.
            conditions:
              - 'IsRootSpan()'
    extensions:
      health_check:
        endpoint: 0.0.0.0:13133
      zpages:
        endpoint: 0.0.0.0:55679
    service:
      extensions: [health_check, zpages]
      pipelines:
        traces:
          receivers: [otlp]
          processors: [memory_limiter, tail_sampling, batch]
          exporters: [ datadog, count/spans_by_facet ]
        metrics:
          receivers: [count/spans_by_facet]
          processors: [deltatocumulative]
          exporters: [prometheus]
      telemetry:
        resource:
          mdai_connection: "{{ .AppName }}"
          service.name: "{{ .AppName }}-trace-sampling-collector"
        metrics:
          readers:
            - pull:
                exporter:
                  prometheus:
                    host: "0.0.0.0"
                    port: 8888
                    with_resource_constant_labels:
                      included:
                        - mdai_connection
                        - service.name