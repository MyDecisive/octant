apiVersion: rbac.authorization.k8s.io/v1
kind: Role
metadata:
  name: {{ .AppName }}-octant-access
  namespace: {{ .Namespace }}
  labels:
    app: {{ .AppName }}
    app.kubernetes.io/instance: {{ .AppName }}
  {{- if .IsArgoSideload }}
  annotations:
    argocd.argoproj.io/tracking-id: {{ .AppName }}:rbac.authorization.k8s.io/v1:mdai/{{ .AppName }}-octant-access
  {{- end }}
rules:
  - apiGroups: [ "" ]
    resources: [ "secrets" ]
    verbs: [ "get" ]
    resourceNames: ["greptimedb-users-auth"]
  - apiGroups: [ "apps" ]
    resources: [ "deployments" ]
    verbs: [ "get" ]
    resourceNames: ["{{ .AppName }}-log-sampling-collector", "{{ .AppName }}-trace-sampling-collector"]
---
apiVersion: rbac.authorization.k8s.io/v1
kind: RoleBinding
metadata:
  name: {{ .AppName }}-octant-access-binding
  namespace: {{ .Namespace }}
  labels:
    app: {{ .AppName }}
    app.kubernetes.io/instance: {{ .AppName }}
  {{- if .IsArgoSideload }}
  annotations:
    argocd.argoproj.io/tracking-id: {{ .AppName }}:rbac.authorization.k8s.io/v1:mdai/{{ .AppName }}-octant-access-binding
  {{- end }}
subjects:
  - kind: ServiceAccount
    name: {{ .ServiceAccount }}
    namespace: {{ .CurrentNamespace }}
roleRef:
  kind: Role
  name: {{ .AppName }}-octant-access
  apiGroup: ""