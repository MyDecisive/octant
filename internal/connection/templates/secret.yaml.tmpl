apiVersion: v1
kind: Secret
metadata:
  name: {{ .ConnectionName }}-integration-secret
  namespace: {{ .Namespace }}
  labels:
    app: {{ .ConnectionName }}-integration-secret
    app.kubernetes.io/instance: {{ .ConnectionName }}-integration-secret
type: Opaque
stringData:
  {{- if .DatadogIntegrationData }}
  api-key: {{ .DatadogIntegrationData.APIKey }}
  site-url: {{ .DatadogIntegrationData.DDUrl }}
  {{- end }}