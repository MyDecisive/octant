    "/budget.v1alpha.FilterService/GetFilter": {
      "post": {
        "summary": "GetFilter returns the current filter setting of the given filter type.\nIf  an update is in progress, this will return with an error code `unavailable`.",
        "operationId": "FilterService_GetFilter",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
