      }
    },
    "/budget.v1alpha.FilterService/UpdateFilter": {
      "post": {
        "summary": "UpdateFilter attempts to update filter setting of the given filter type.\nIf an update is in progress, this will immediately return with an error code `unavailable`.\nOtherwise, this will continuously give update until the update is complete or errored.",
        "operationId": "FilterService_UpdateFilter",
        "responses": {
          "200": {
            "description": "A successful response.(streaming responses)",
            "schema": {
              "type": "object",
              "properties": {
                "result": {
                  "$ref": "#/definitions/v1alphaUpdateFilterResponse"
                },
                "error": {
                  "$ref": "#/definitions/googleRpcStatus"
                }
              },
              "title": "Stream result of v1alphaUpdateFilterResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/googleRpcStatus"
            }
